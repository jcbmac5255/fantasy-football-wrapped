# Env values used only by the Vitest suite (loaded automatically in test mode).
# Absolute URLs so tests that build URLs/assert on them are deterministic
# without depending on a browser origin. Safe to commit — no secrets.

VITE_ALL_FEATURES_FREE=true

VITE_TRENDS_RECAP=https://test.local/api/ai?kind=trends
VITE_LEAGUE_RECAP=https://test.local/api/ai?kind=league-recap
VITE_WEEKLY_REPORT=https://test.local/api/ai?kind=weekly-report
VITE_PREMIUM_WEEKLY_REPORT=https://test.local/api/ai?kind=premium-report
VITE_WEEKLY_REPORT_AUDIO=https://test.local/api/ai?kind=audio
VITE_MANAGER_PROFILES=https://test.local/api/ai?kind=manager-profiles
VITE_WEEKLY_PREVIEW=https://test.local/api/ai?kind=weekly-preview

VITE_PLAYERS_URL=https://test.local/api/player?op=byIds&ids=
VITE_PLAYER_ID_LOOKUP=https://test.local/api/player?op=lookup
VITE_PLAYER_NEWS=https://test.local/api/player?op=news

VITE_LEAGUE_URL=https://test.local/api/log?type=league
VITE_USERNAME_URL=https://test.local/api/log?type=username
VITE_ACCOUNT_ALERT=https://test.local/api/log?type=alert
VITE_LEAGUE_COUNT=https://test.local/api/log?type=count

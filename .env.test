VITE_WEEKLY_REPORT_AUDIO=https://test.local/api/weekly-report-audio
VITE_MANAGER_PROFILES=https://test.local/api/manager-profiles
VITE_WEEKLY_PREVIEW=https://test.local/api/weekly-preview

VITE_PLAYERS_URL=https://test.local/api/players?ids=
VITE_PLAYER_ID_LOOKUP=https://test.local/api/player-id-lookup
VITE_PLAYER_NEWS=https://test.local/api/player-news

VITE_LEAGUE_URL=https://test.local/api/log-league
VITE_USERNAME_URL=https://test.local/api/log-username
VITE_ACCOUNT_ALERT=https://test.local/api/account-alert

# Self-hosted production config (safe to commit — no secrets here).
# These point the frontend at the bundled Vercel serverless functions in /api.
# Secrets (OpenAI / Supabase keys) are set in the Vercel dashboard, NOT here.

# All premium features are free in this build. Set to "false" to restore a paywall.
VITE_ALL_FEATURES_FREE=true

# AI endpoints (OpenAI-backed serverless functions)
VITE_TRENDS_RECAP=/api/trends
VITE_LEAGUE_RECAP=/api/league-recap
VITE_WEEKLY_REPORT=/api/weekly-report
VITE_PREMIUM_WEEKLY_REPORT=/api/premium-report
VITE_WEEKLY_REPORT_AUDIO=/api/weekly-report-audio
VITE_MANAGER_PROFILES=/api/manager-profiles
VITE_WEEKLY_PREVIEW=/api/weekly-preview

# Player data endpoints (Sleeper-backed serverless functions)
VITE_PLAYERS_URL=/api/players?ids=
VITE_PLAYER_ID_LOOKUP=/api/player-id-lookup
VITE_PLAYER_NEWS=/api/player-news

# Logging / stats endpoints (best-effort, optional Supabase storage)
VITE_LEAGUE_URL=/api/log-league
VITE_USERNAME_URL=/api/log-username
VITE_ACCOUNT_ALERT=/api/account-alert
VITE_LEAGUE_COUNT=/api/league-count

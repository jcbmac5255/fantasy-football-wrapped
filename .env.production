# Self-hosted production config (safe to commit — no secrets here).
# These point the frontend at the bundled Vercel serverless functions in /api.
# Secrets (OpenAI / Supabase keys) are set in the Vercel dashboard, NOT here.
#
# To stay within Vercel's Hobby plan limit (12 functions), the backends are
# consolidated into a few routers selected by query param:
#   /api/ai?kind=...   /api/player?op=...   /api/log?type=...   /api/espn

# All premium features are free in this build. Set to "false" to restore a paywall.
VITE_ALL_FEATURES_FREE=true

# AI endpoints (OpenAI-backed) -> api/ai.ts
VITE_TRENDS_RECAP=/api/ai?kind=trends
VITE_LEAGUE_RECAP=/api/ai?kind=league-recap
VITE_WEEKLY_REPORT=/api/ai?kind=weekly-report
VITE_PREMIUM_WEEKLY_REPORT=/api/ai?kind=premium-report
VITE_WEEKLY_REPORT_AUDIO=/api/ai?kind=audio
VITE_MANAGER_PROFILES=/api/ai?kind=manager-profiles
VITE_WEEKLY_PREVIEW=/api/ai?kind=weekly-preview

# Player data endpoints (Sleeper-backed) -> api/player.ts
VITE_PLAYERS_URL=/api/player?op=byIds&ids=
VITE_PLAYER_ID_LOOKUP=/api/player?op=lookup
VITE_PLAYER_NEWS=/api/player?op=news

# Logging / stats endpoints (best-effort Supabase) -> api/log.ts
VITE_LEAGUE_URL=/api/log?type=league
VITE_USERNAME_URL=/api/log?type=username
VITE_ACCOUNT_ALERT=/api/log?type=alert
VITE_LEAGUE_COUNT=/api/log?type=count

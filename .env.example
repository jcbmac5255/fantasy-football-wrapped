# ─────────────────────────────────────────────────────────────────────────────
# ffwrapped self-hosted environment template.
#
# • The VITE_ endpoint paths already have sensible defaults in .env.production
#   (committed) and do not need to be set here.
# • For LOCAL dev, copy this file to `.env.local` and fill in the values below.
# • For PRODUCTION, set the same values in the Vercel dashboard
#   (Project → Settings → Environment Variables).
#
# See SETUP.md for step-by-step instructions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: OpenAI (server-side only — NOT a VITE_ var, never exposed to the browser)
OPENAI_API_KEY=sk-...
# Optional model overrides (defaults shown):
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy

# ── Required for accounts/login: Supabase
# Build-time (browser) — the anon key is publishable by design:
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Runtime (server-side, used by the /api functions to verify sessions). Set these
# to the SAME url/anon key as above. They can be left unset if you mirror the
# VITE_ ones, but setting them explicitly is clearer:
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ── Optional: enables league/username logging + the landing-page league count.
# The service-role key is a SECRET — server-side only, never prefix with VITE_.
# Leave unset to disable analytics logging (everything else still works).
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional: PostHog product analytics. Leave unset to disable.
# VITE_POSTHOG_KEY=

# ── Optional: restore the original paywall (default is everything-free).
# VITE_ALL_FEATURES_FREE=false
